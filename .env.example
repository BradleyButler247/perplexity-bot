# ============================================================
# Polymarket Trading Bot v36 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------
# Wallet / Authentication
# ------------------------------------

# Your wallet's private key (from reveal.polymarket.com)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy wallet address (the address you deposit USDC to).
# Required for email/Magic and browser-wallet login types.
# Leave blank if you're using a raw EOA without a proxy.
POLYMARKET_PROXY_ADDRESS=

# Signature type matching your Polymarket login method:
#   0 = EOA (direct wallet, no proxy)
#   1 = Email / Magic.link wallet
#   2 = Browser wallet (MetaMask, Coinbase Wallet, etc.)
SIGNATURE_TYPE=2

# ------------------------------------
# Copy Trading Strategy
# ------------------------------------

# The public wallet address to mirror trades from (manual override).
# Leave blank to use auto-discovery (AUTO_DISCOVER_WALLETS=true).
TARGET_WALLET=

# ------------------------------------
# Trading Mode
# ------------------------------------

# paper  — Log trades but never submit real orders.
# micro  — Real orders capped at MICRO_TRADE_SIZE per trade.
# live   — Full-size real orders.
TRADING_MODE=micro

# Size in USD for each trade in micro mode
MICRO_TRADE_SIZE=5.00

# ------------------------------------
# Risk / Position Limits
# ------------------------------------

# Maximum USDC to spend on a single position
MAX_POSITION_SIZE=50

# Maximum total USDC exposure across all open positions
MAX_TOTAL_EXPOSURE=500

# Maximum number of concurrent open positions
MAX_POSITIONS=20

# Minimum market volume (USDC) to consider trading
MIN_LIQUIDITY=10000

# Kill switch: halt all trading if total P&L drops below this (negative number)
KILL_SWITCH_THRESHOLD=-100

# Daily drawdown circuit breaker: halt if daily losses exceed this
# fraction of estimated bankroll (0.05 = 5%). Resets at midnight UTC.
MAX_DAILY_DRAWDOWN_PCT=0.05

# Pause trading for 15 min after this many consecutive losing trades
MAX_CONSECUTIVE_LOSSES=3

# ------------------------------------
# Strategy Tuning
# ------------------------------------

# Arbitrage: minimum net edge after fees to trigger (0.01 = 1%)
ARBITRAGE_MIN_EDGE=0.01

# Copy trading: fixed USDC amount per mirrored trade
COPY_TRADE_SIZE=10

# Copy trading: max age of a trade to mirror (seconds). 600 = 10 min.
COPY_TRADE_MAX_AGE=600

# Signal: minimum composite score to open a position (0.01 = 1%)
SIGNAL_MIN_EDGE=0.01

# Maximum acceptable slippage before aborting an order (0.03 = 3%)
MAX_SLIPPAGE=0.03

# ------------------------------------
# Trade Management (Take-Profit / Stop-Loss / Exits)
# ------------------------------------

# Close a position when unrealised P&L reaches this gain (0.15 = 15%)
TAKE_PROFIT_PCT=0.15

# Close a position when unrealised P&L drops to this loss (0.10 = 10%)
STOP_LOSS_PCT=0.10

# Maximum seconds to hold a position before force-exiting (86400 = 24h)
MAX_HOLD_TIME=86400

# Activate trailing stop once a position has gained this much (0.10 = 10%)
TRAILING_STOP_ACTIVATION=0.10

# Once trailing stop is active, sell if price drops this far from peak
TRAILING_STOP_PCT=0.05

# ------------------------------------
# Wallet Auto-Discovery
# ------------------------------------

# Auto-discover profitable wallets from the Polymarket leaderboard
AUTO_DISCOVER_WALLETS=true

# How often to re-run wallet discovery (21600 = 6 hours)
WALLET_DISCOVERY_INTERVAL=21600

# Minimum win rate for a discovered wallet to qualify (0.55 = 55%)
MIN_WIN_RATE=0.55

# Minimum closed positions to qualify (10 = filters out pure luck)
MIN_CLOSED_POSITIONS=10

# Maximum wallets to follow simultaneously
MAX_COPY_WALLETS=5

# Leaderboard categories to search (comma-separated)
WALLET_CATEGORIES=OVERALL,SPORTS,CRYPTO,POLITICS

# ------------------------------------
# AI Probability Engine (Claude)
# ------------------------------------

# Your Anthropic API key. Required for the AI-powered strategy.
# Get one at https://console.anthropic.com/
# Leave blank to disable the AI strategy (other strategies still work).
ANTHROPIC_API_KEY=

# Claude model to use
AI_MODEL=claude-sonnet-4-20250514

# Minimum edge (AI estimate vs market price) to trigger a trade.
# 0.05 = 5% — AI must disagree with the market by at least 5%.
AI_MIN_EDGE=0.05

# ------------------------------------
# Self-Learning Optimizer
# ------------------------------------

# Enable the adaptive self-learning engine
OPTIMIZER_ENABLED=true

# Minimum trades before the optimizer starts adjusting weights.
# Set to 200 for small bankrolls to let strategies prove themselves first.
OPTIMIZER_MIN_TRADES=200

# How often the optimizer runs (seconds). 3600 = every hour.
OPTIMIZER_INTERVAL=3600

# Maximum parameter change per cycle (0.15 = 15%)
OPTIMIZER_MAX_SHIFT=0.15

# Number of recent trades to analyse per cycle
OPTIMIZER_LOOKBACK=200

# ------------------------------------
# LP Rewards Strategy
# ------------------------------------

# Enable/disable the LP rewards strategy
LP_ENABLED=true

# Fraction of bankroll to allocate to LP (0.20 = 20%)
LP_CAPITAL_PCT=0.20

# Maximum markets to provide liquidity in
LP_MAX_MARKETS=5

# Cancel and re-place LP orders every N seconds (300 = 5 min)
LP_REFRESH_INTERVAL=300

# ------------------------------------
# Base Rate Rules
# ------------------------------------

# Minimum historical base rate for full sizing (0.12 = 12%)
BASE_RATE_MIN=0.12

# Size reduction if below base rate minimum (0.50 = cut 50%)
BASE_RATE_SIZE_CUT=0.50

# Prefer holding to resolution unless EV flips negative
HOLD_TO_RESOLUTION=true

# ------------------------------------
# Bayesian Re-evaluation
# ------------------------------------

# Re-evaluate open AI positions every N cycles
REEVALUATE_INTERVAL=10

# ------------------------------------
# Whale Detection
# ------------------------------------

# Minimum single-trade USD to flag as whale activity
WHALE_MIN_TRADE_USD=5000

# How far back to scan for whale activity (minutes)
WHALE_LOOKBACK_MINUTES=10

# ------------------------------------
# Bot Behaviour
# ------------------------------------

# Seconds between full strategy scan cycles
POLL_INTERVAL=15

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ------------------------------------
# Polygon RPC
# ------------------------------------

# Polygon RPC URL for the auto-redeemer.
# Default polygon-rpc.com returns 401; use a public alternative.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
