# ============================================================
# Polymarket Trading Bot - Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------
# Wallet / Authentication
# ------------------------------------

# Your wallet's private key (from reveal.polymarket.com)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy wallet address (the address you deposit USDC to).
# Required for email/Magic and browser-wallet login types.
# Leave blank if you're using a raw EOA without a proxy.
POLYMARKET_PROXY_ADDRESS=

# Signature type matching your Polymarket login method:
#   0 = EOA (direct wallet, no proxy)
#   1 = Email / Magic.link wallet
#   2 = Browser wallet (MetaMask, Coinbase Wallet, etc.)
SIGNATURE_TYPE=0

# ------------------------------------
# Copy Trading Strategy
# ------------------------------------

# The public wallet address to mirror trades from (manual override).
# Leave blank to use auto-discovery (AUTO_DISCOVER_WALLETS=true).
TARGET_WALLET=

# ------------------------------------
# Trading Mode
# ------------------------------------

# Controls how the bot executes trades.  Choose ONE of three modes:
#
#   paper  — Log trades but never submit real orders (safe default, no risk).
#            Best for initial setup and strategy validation.
#
#   micro  — Place REAL orders but cap each trade at MICRO_TRADE_SIZE USD.
#            Use this to verify live connectivity and test performance with
#            minimal financial exposure ($1-5 per trade).
#
#   live   — Full-size real orders.  Use after validating in paper/micro.
#
# Backward compat: if TRADING_MODE is unset, the legacy PAPER_TRADE boolean
# is used (true → "paper", false → "live").
TRADING_MODE=paper

# Size in USD for each trade in micro mode (default: $1.50)
MICRO_TRADE_SIZE=5.00

# ------------------------------------
# Risk / Position Limits
# ------------------------------------

# Maximum USDC to spend on a single position
MAX_POSITION_SIZE=50

# Maximum total USDC exposure across all open positions
MAX_TOTAL_EXPOSURE=500

# Maximum number of concurrent open positions
MAX_POSITIONS=10

# Minimum market volume (USDC) to consider trading
MIN_LIQUIDITY=10000

# Kill switch: halt all trading if total P&L drops below this (negative number)
KILL_SWITCH_THRESHOLD=-100

# Daily drawdown circuit breaker: halt trading if daily losses exceed
# this fraction of estimated bankroll (0.05 = 5%). Resets at midnight UTC.
MAX_DAILY_DRAWDOWN_PCT=0.05

# Pause trading for 15 minutes after this many consecutive losing trades
MAX_CONSECUTIVE_LOSSES=3

# ------------------------------------
# Strategy Tuning
# ------------------------------------

# Arbitrage: minimum net edge after fees to trigger (0.02 = 2%)
ARBITRAGE_MIN_EDGE=0.02

# Copy trading: fixed USDC amount per mirrored trade
COPY_TRADE_SIZE=10

# Copy trading: skip mirroring if the target trade is older than this many seconds
COPY_TRADE_MAX_AGE=120

# Signal: minimum composite score to open a position (0.05 = 5%)
SIGNAL_MIN_EDGE=0.05

# Maximum acceptable slippage before aborting an order (0.03 = 3%)
MAX_SLIPPAGE=0.03

# ------------------------------------
# Trade Management (Take-Profit / Stop-Loss / Exits)
# ------------------------------------

# Close a position when unrealised P&L reaches this gain (0.15 = 15%)
TAKE_PROFIT_PCT=0.15

# Close a position when unrealised P&L drops to this loss (0.10 = 10%)
STOP_LOSS_PCT=0.10

# Maximum seconds to hold a position before force-exiting (86400 = 24 hours)
# The bot is designed for short-term trading, not hold-to-resolution.
MAX_HOLD_TIME=86400

# Activate trailing stop once a position has gained this much (0.10 = 10%)
TRAILING_STOP_ACTIVATION=0.10

# Once trailing stop is active, sell if price drops this far from peak (0.05 = 5%)
TRAILING_STOP_PCT=0.05

# ------------------------------------
# Wallet Auto-Discovery
# ------------------------------------

# If true and TARGET_WALLET is not set, the bot will automatically find
# profitable wallets on the Polymarket leaderboard to copy trade from.
AUTO_DISCOVER_WALLETS=true

# How often to re-run wallet discovery (21600 = 6 hours).
# Discovery results are cached between runs to avoid excessive API calls.
WALLET_DISCOVERY_INTERVAL=21600

# Minimum win rate for a discovered wallet to qualify (0.55 = 55%)
MIN_WIN_RATE=0.55

# Minimum number of closed positions required to qualify (filters out luck)
MIN_CLOSED_POSITIONS=20

# Maximum number of wallets to follow simultaneously
MAX_COPY_WALLETS=3

# Comma-separated leaderboard categories to search.
# Options: OVERALL, POLITICS, SPORTS, CRYPTO, CULTURE, WEATHER, ECONOMICS, TECH, FINANCE
WALLET_CATEGORIES=OVERALL

# ------------------------------------
# AI Probability Engine (Claude)
# ------------------------------------

# Your Anthropic API key. Required for the AI-powered strategy.
# Get one at https://console.anthropic.com/
# Leave blank to disable the AI strategy (other strategies still work).
ANTHROPIC_API_KEY=

# Claude model to use (default: claude-sonnet-4-20250514)
# Sonnet is the best balance of speed, cost, and accuracy.
AI_MODEL=claude-sonnet-4-20250514

# Minimum edge (AI estimate vs market price) to trigger a trade.
# 0.08 = 8% — AI must disagree with the market by at least 8%.
AI_MIN_EDGE=0.08

# ------------------------------------
# Self-Learning Optimizer
# ------------------------------------

# Enable or disable the adaptive self-learning engine.
# When enabled, the bot analyses its own trade history and automatically
# adjusts strategy weights and parameters to improve performance.
OPTIMIZER_ENABLED=true

# Minimum number of completed trades before the optimizer begins adapting.
# Set higher for more reliable data; lower to start adapting sooner.
OPTIMIZER_MIN_TRADES=50

# How often the optimizer runs (in seconds).  3600 = every hour.
OPTIMIZER_INTERVAL=3600

# Maximum parameter change per optimization cycle (0.15 = 15%).
# Lower = more conservative.  Higher = adapts faster but risks overfit.
OPTIMIZER_MAX_SHIFT=0.15

# Number of recent trades to analyse during each optimization cycle.
OPTIMIZER_LOOKBACK=200

# ------------------------------------
# LP Rewards Strategy (v34)
# ------------------------------------

# Enable/disable the LP rewards strategy
LP_ENABLED=true

# Fraction of bankroll to allocate to LP (0.20 = 20%)
LP_CAPITAL_PCT=0.20

# Maximum number of markets to provide liquidity in
LP_MAX_MARKETS=5

# Cancel and re-place LP orders every N seconds (300 = 5 min)
LP_REFRESH_INTERVAL=300

# ------------------------------------
# Base Rate Rules (v34)
# ------------------------------------

# Minimum historical base rate to enter at full size (0.12 = 12%)
BASE_RATE_MIN=0.12

# Cut position size by this fraction if below base rate minimum (0.50 = 50%)
BASE_RATE_SIZE_CUT=0.50

# When true, prefer holding to resolution unless EV flips negative.
# Stat: 89% of retail traders exit early; avg profit +18% vs +74% held.
HOLD_TO_RESOLUTION=true

# ------------------------------------
# Bayesian Re-evaluation (v34)
# ------------------------------------

# Re-evaluate open AI positions every N cycles
REEVALUATE_INTERVAL=10

# ------------------------------------
# Bot Behaviour
# ------------------------------------

# Seconds between full strategy scan cycles
POLL_INTERVAL=30

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ------------------------------------
# Whale Detection (v35)
# ------------------------------------

# Minimum single-trade USD value to flag as a whale trade
WHALE_MIN_TRADE_USD=5000

# How far back to look for recent whale activity (minutes)
WHALE_LOOKBACK_MINUTES=10

# ------------------------------------
# Polygon RPC
# ------------------------------------

# Polygon RPC URL for the auto-redeemer (resolved position claiming).
# The default polygon-rpc.com returns 401; use a public alternative.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
