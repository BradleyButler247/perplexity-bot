# Required
POLYMARKET_PROXY_ADDRESS=0x1ed8b2a6117892f3b1d948da4503604ecfd956fa
PRIVATE_KEY=0x6fa83da1672aec261762ac942356a423a5903dca0d39181b3daa49414663cb5b
SIGNATURE_TYPE=1

# Trading mode
TRADING_MODE=micro
MICRO_TRADE_SIZE=5

# Risk limits (defaults are fine to start)
MAX_POSITION_SIZE=50
MAX_TOTAL_EXPOSURE=500
MAX_POSITIONS=20
MIN_LIQUIDITY=10000
KILL_SWITCH_THRESHOLD=-100

# Strategy tuning (lowered for more activity)
ARBITRAGE_MIN_EDGE=0.02
SIGNAL_MIN_EDGE=0.02
COPY_TRADE_SIZE=10
COPY_TRADE_MAX_AGE=120
MAX_SLIPPAGE=0.03

# Trade management
TAKE_PROFIT_PCT=0.15
STOP_LOSS_PCT=0.10
MAX_HOLD_TIME=86400
TRAILING_STOP_ACTIVATION=0.10
TRAILING_STOP_PCT=0.05

# Wallet discovery (lowered thresholds from your earlier change)
AUTO_DISCOVER_WALLETS=true
WALLET_DISCOVERY_INTERVAL=21600
MIN_WIN_RATE=0.50
MIN_CLOSED_POSITIONS=10
# Change MAX_COPY_WALLETS to 10 when bankroll is up
# Update bot to prevent conflicting buys (One buys up the other buys down)
MAX_COPY_WALLETS=5
WALLET_CATEGORIES=OVERALL

# Optimizer
OPTIMIZER_ENABLED=true
OPTIMIZER_MIN_TRADES=50
OPTIMIZER_INTERVAL=3600
OPTIMIZER_MAX_SHIFT=0.15
OPTIMIZER_LOOKBACK=200

# Bot behavior
POLL_INTERVAL=15
LOG_LEVEL=INFO
