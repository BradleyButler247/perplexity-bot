SIGNAL_MIN_EDGE=0.02
COPY_TRADE_SIZE=10
COPY_TRADE_MAX_AGE=600
MAX_SLIPPAGE=0.03

# Trade management
TAKE_PROFIT_PCT=0.15
STOP_LOSS_PCT=0.10
MAX_HOLD_TIME=86400
TRAILING_STOP_ACTIVATION=0.10
TRAILING_STOP_PCT=0.05
BASE_RATE_MIN=0.12
BASE_RATE_SIZE_CUT=0.50
HOLD_TO_RESOLUTION=true
REEVALUATE_INTERVAL=10
MAX_DAILY_DRAWDOWN_PCT=0.5
MAX_CONSECUTIVE_LOSSES=3
WHALE_MIN_TRADE_USD=5000
WHALE_LOOKBACK_MINUTES=10

# Wallet discovery
AUTO_DISCOVER_WALLETS=true
WALLET_DISCOVERY_INTERVAL=21600
MIN_WIN_RATE=0.50
MIN_CLOSED_POSITIONS=10
MAX_COPY_WALLETS=10
WALLET_CATEGORIES=OVERALL,SPORTS,CRYPTO,POLITICS,SPORTS,CRYPTO,POLITICS

# Optimizer
